{
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "displayName": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "url": {
      "type": "string"
    },
    "globalParameters": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/NestedParameter"
      }
    },
    "commands": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/NestedCommand"
      }
    },
    "exclusionGroups": {
      "anyOf": [
        {
          "type": "array",
          "items": {
            "$ref": "#/definitions/NestedExclusionGroup"
          }
        },
        {
          "type": "null"
        }
      ]
    },
    "metadata": {
      "$ref": "#/definitions/ToolMetadata"
    }
  },
  "required": [
    "commands",
    "displayName",
    "globalParameters",
    "name"
  ],
  "definitions": {
    "NestedParameter": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "parameterType": {
          "$ref": "#/definitions/ParameterType"
        },
        "dataType": {
          "$ref": "#/definitions/ParameterDataType"
        },
        "metadata": {
          "$ref": "#/definitions/ParameterMetadata"
        },
        "isRequired": {
          "type": "boolean"
        },
        "isRepeatable": {
          "type": "boolean"
        },
        "isGlobal": {
          "type": "boolean"
        },
        "defaultValue": {
          "type": "string"
        },
        "shortFlag": {
          "type": "string"
        },
        "longFlag": {
          "type": "string"
        },
        "position": {
          "type": "number"
        },
        "sortOrder": {
          "type": "number"
        },
        "arraySeparator": {
          "type": "string"
        },
        "keyValueSeparator": {
          "type": "string"
        },
        "enumValues": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/NestedParameterEnumValue"
          }
        },
        "validations": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/NestedParameterValidation"
          }
        },
        "dependencies": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/NestedParameterDependency"
          }
        }
      },
      "required": [
        "dataType",
        "isGlobal",
        "isRepeatable",
        "isRequired",
        "name",
        "parameterType"
      ]
    },
    "ParameterType": {
      "enum": [
        "Argument",
        "Flag",
        "Option"
      ],
      "type": "string"
    },
    "ParameterDataType": {
      "enum": [
        "Boolean",
        "Enum",
        "Number",
        "String"
      ],
      "type": "string"
    },
    "ParameterMetadata": {
      "type": "object",
      "properties": {
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "NestedParameterEnumValue": {
      "type": "object",
      "properties": {
        "value": {
          "type": "string"
        },
        "displayName": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "isDefault": {
          "type": "boolean"
        },
        "sortOrder": {
          "type": "number"
        }
      },
      "required": [
        "displayName",
        "value"
      ]
    },
    "NestedParameterValidation": {
      "type": "object",
      "properties": {
        "validationType": {
          "$ref": "#/definitions/ParameterValidationType"
        },
        "validationValue": {
          "type": "string"
        },
        "errorMessage": {
          "type": "string"
        }
      },
      "required": [
        "errorMessage",
        "validationType",
        "validationValue"
      ]
    },
    "ParameterValidationType": {
      "enum": [
        "max_length",
        "max_value",
        "min_length",
        "min_value",
        "regex"
      ],
      "type": "string"
    },
    "NestedParameterDependency": {
      "type": "object",
      "properties": {
        "dependsOnParameter": {
          "type": "string"
        },
        "dependencyType": {
          "$ref": "#/definitions/ParameterDependencyType"
        },
        "conditionValue": {
          "type": "string"
        }
      },
      "required": [
        "dependencyType",
        "dependsOnParameter"
      ]
    },
    "ParameterDependencyType": {
      "enum": [
        "conflicts_with",
        "requires"
      ],
      "type": "string"
    },
    "NestedCommand": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "isDefault": {
          "type": "boolean"
        },
        "sortOrder": {
          "type": "number"
        },
        "parameters": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/NestedParameter"
          }
        },
        "subcommands": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/NestedCommand"
          }
        }
      },
      "required": [
        "isDefault",
        "name",
        "parameters",
        "sortOrder",
        "subcommands"
      ]
    },
    "NestedExclusionGroup": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "exclusionType": {
          "$ref": "#/definitions/ExclusionType"
        },
        "parameters": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "exclusionType",
        "name",
        "parameters"
      ]
    },
    "ExclusionType": {
      "enum": [
        "mutual_exclusive",
        "required_one_of"
      ],
      "type": "string"
    },
    "ToolMetadata": {
      "type": "object"
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}