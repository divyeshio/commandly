{
  "$schema": "https://commandly.divyeshio.in/specification/flat.json",
  "name": "dnsx",
  "displayName": "DNSX",
  "info": {
    "description": "A fast and multi-purpose DNS toolkit designed for running DNS queries.",
    "version": "1.2.3",
    "url": "https://github.com/projectdiscovery/dnsx"
  },
  "commands": [
    {
      "name": "dnsx",
      "description": "Root command for dnsx CLI.",
      "isDefault": true,
      "sortOrder": 1,
      "key": "dnsx"
    }
  ],
  "parameters": [
    {
      "name": "List",
      "description": "List of sub(domains)/hosts to resolve (file or stdin).",
      "parameterType": "Option",
      "dataType": "String",
      "shortFlag": "-l",
      "longFlag": "-list",
      "key": "list",
      "commandKey": "dnsx"
    },
    {
      "name": "Domain",
      "description": "List of domain to bruteforce (file or comma separated or stdin).",
      "parameterType": "Option",
      "dataType": "String",
      "shortFlag": "-d",
      "longFlag": "-domain",
      "key": "domain",
      "commandKey": "dnsx"
    },
    {
      "name": "Wordlist",
      "description": "List of words to bruteforce (file or comma separated or stdin).",
      "parameterType": "Option",
      "dataType": "String",
      "shortFlag": "-w",
      "longFlag": "-wordlist",
      "key": "wordlist",
      "commandKey": "dnsx"
    },
    {
      "name": "A",
      "description": "Query A record (default).",
      "parameterType": "Flag",
      "dataType": "Boolean",
      "longFlag": "-a",
      "key": "a",
      "commandKey": "dnsx"
    },
    {
      "name": "AAAA",
      "description": "Query AAAA record.",
      "parameterType": "Flag",
      "dataType": "Boolean",
      "longFlag": "-aaaa",
      "key": "aaaa",
      "commandKey": "dnsx"
    },
    {
      "name": "CNAME",
      "description": "Query CNAME record.",
      "parameterType": "Flag",
      "dataType": "Boolean",
      "longFlag": "-cname",
      "key": "cname",
      "commandKey": "dnsx"
    },
    {
      "name": "NS",
      "description": "Query NS record.",
      "parameterType": "Flag",
      "dataType": "Boolean",
      "longFlag": "-ns",
      "key": "ns",
      "commandKey": "dnsx"
    },
    {
      "name": "TXT",
      "description": "Query TXT record.",
      "parameterType": "Flag",
      "dataType": "Boolean",
      "longFlag": "-txt",
      "key": "txt",
      "commandKey": "dnsx"
    },
    {
      "name": "SRV",
      "description": "Query SRV record.",
      "parameterType": "Flag",
      "dataType": "Boolean",
      "longFlag": "-srv",
      "key": "srv",
      "commandKey": "dnsx"
    },
    {
      "name": "PTR",
      "description": "Query PTR record.",
      "parameterType": "Flag",
      "dataType": "Boolean",
      "longFlag": "-ptr",
      "key": "ptr",
      "commandKey": "dnsx"
    },
    {
      "name": "MX",
      "description": "Query MX record.",
      "parameterType": "Flag",
      "dataType": "Boolean",
      "longFlag": "-mx",
      "key": "mx",
      "commandKey": "dnsx"
    },
    {
      "name": "SOA",
      "description": "Query SOA record.",
      "parameterType": "Flag",
      "dataType": "Boolean",
      "longFlag": "-soa",
      "key": "soa",
      "commandKey": "dnsx"
    },
    {
      "name": "ANY",
      "description": "Query ANY record.",
      "parameterType": "Flag",
      "dataType": "Boolean",
      "longFlag": "-any",
      "key": "any",
      "commandKey": "dnsx"
    },
    {
      "name": "AXFR",
      "description": "Query AXFR.",
      "parameterType": "Flag",
      "dataType": "Boolean",
      "longFlag": "-axfr",
      "key": "axfr",
      "commandKey": "dnsx"
    },
    {
      "name": "CAA",
      "description": "Query CAA record.",
      "parameterType": "Flag",
      "dataType": "Boolean",
      "longFlag": "-caa",
      "key": "caa",
      "commandKey": "dnsx"
    },
    {
      "name": "Recon",
      "description": "Query all the DNS records (A, AAAA, CNAME, NS, TXT, SRV, PTR, MX, SOA, AXFR, CAA).",
      "parameterType": "Flag",
      "dataType": "Boolean",
      "longFlag": "-recon",
      "key": "recon",
      "commandKey": "dnsx"
    },
    {
      "name": "Exclude Type",
      "description": "DNS query type to exclude (A, AAAA, CNAME, NS, TXT, SRV, PTR, MX, SOA, AXFR, CAA) (default none).",
      "parameterType": "Option",
      "dataType": "Enum",
      "shortFlag": "-e",
      "longFlag": "-exclude-type",
      "key": "exclude-type",
      "commandKey": "dnsx",
      "enum": {
        "allowMultiple": true,
        "values": [
          {
            "value": "A",
            "displayName": "A"
          },
          {
            "value": "AAAA",
            "displayName": "AAAA"
          },
          {
            "value": "CNAME",
            "displayName": "CNAME"
          },
          {
            "value": "NS",
            "displayName": "NS"
          },
          {
            "value": "TXT",
            "displayName": "TXT"
          },
          {
            "value": "SRV",
            "displayName": "SRV"
          },
          {
            "value": "PTR",
            "displayName": "PTR"
          },
          {
            "value": "MX",
            "displayName": "MX"
          },
          {
            "value": "SOA",
            "displayName": "SOA"
          },
          {
            "value": "AXFR",
            "displayName": "AXFR"
          },
          {
            "value": "CAA",
            "displayName": "CAA"
          }
        ]
      }
    },
    {
      "name": "Response",
      "description": "Display DNS response.",
      "parameterType": "Flag",
      "dataType": "Boolean",
      "shortFlag": "-re",
      "longFlag": "-resp",
      "key": "resp",
      "commandKey": "dnsx"
    },
    {
      "name": "Response Only",
      "description": "Display DNS response only.",
      "parameterType": "Flag",
      "dataType": "Boolean",
      "shortFlag": "-ro",
      "longFlag": "-resp-only",
      "key": "resp-only",
      "commandKey": "dnsx"
    },
    {
      "name": "Response Code",
      "description": "Filter result by DNS status code (e.g. -rcode noerror, servfail, refused).",
      "parameterType": "Option",
      "dataType": "String",
      "shortFlag": "-rc",
      "longFlag": "-rcode",
      "key": "rcode",
      "commandKey": "dnsx"
    },
    {
      "name": "CDN",
      "description": "Display CDN name.",
      "parameterType": "Flag",
      "dataType": "Boolean",
      "longFlag": "-cdn",
      "key": "cdn",
      "commandKey": "dnsx"
    },
    {
      "name": "ASN",
      "description": "Display host ASN information.",
      "parameterType": "Flag",
      "dataType": "Boolean",
      "longFlag": "-asn",
      "key": "asn",
      "commandKey": "dnsx"
    },
    {
      "name": "Threads",
      "description": "Number of concurrent threads to use (default 100).",
      "parameterType": "Option",
      "dataType": "Number",
      "shortFlag": "-t",
      "longFlag": "-threads",
      "key": "threads",
      "commandKey": "dnsx"
    },
    {
      "name": "Rate Limit",
      "description": "Number of DNS requests/second to make (disabled by default) (default -1).",
      "parameterType": "Option",
      "dataType": "Number",
      "shortFlag": "-rl",
      "longFlag": "-rate-limit",
      "key": "rate-limit",
      "commandKey": "dnsx"
    },
    {
      "name": "Update",
      "description": "Update dnsx to latest version.",
      "parameterType": "Flag",
      "dataType": "Boolean",
      "shortFlag": "-up",
      "longFlag": "-update",
      "key": "update",
      "commandKey": "dnsx"
    },
    {
      "name": "Disable Update Check",
      "description": "Disable automatic dnsx update check.",
      "parameterType": "Flag",
      "dataType": "Boolean",
      "shortFlag": "-duc",
      "longFlag": "-disable-update-check",
      "key": "disable-update-check",
      "commandKey": "dnsx"
    },
    {
      "name": "Output",
      "description": "File to write output.",
      "parameterType": "Option",
      "dataType": "String",
      "shortFlag": "-o",
      "longFlag": "-output",
      "key": "output",
      "commandKey": "dnsx"
    },
    {
      "name": "JSON Output",
      "description": "Write output in JSONL(ines) format.",
      "parameterType": "Flag",
      "dataType": "Boolean",
      "shortFlag": "-j",
      "longFlag": "-json",
      "key": "json",
      "commandKey": "dnsx"
    },
    {
      "name": "Omit Raw",
      "description": "Omit raw DNS response from JSONL output.",
      "parameterType": "Flag",
      "dataType": "Boolean",
      "shortFlag": "-or",
      "longFlag": "-omit-raw",
      "key": "or",
      "commandKey": "dnsx"
    },
    {
      "name": "Health Check",
      "description": "Display dnsx health status.",
      "parameterType": "Flag",
      "dataType": "Boolean",
      "longFlag": "-health-check",
      "key": "health-check",
      "commandKey": "dnsx"
    },
    {
      "name": "Verbose",
      "description": "Show verbose output.",
      "parameterType": "Flag",
      "dataType": "Boolean",
      "shortFlag": "-v",
      "longFlag": "-verbose",
      "key": "verbose",
      "commandKey": "dnsx"
    },
    {
      "name": "No Color",
      "description": "Disable colors in CLI output.",
      "parameterType": "Flag",
      "dataType": "Boolean",
      "longFlag": "-no-color",
      "key": "no-color",
      "commandKey": "dnsx"
    },
    {
      "name": "Silent",
      "description": "Show only results in CLI output.",
      "parameterType": "Flag",
      "dataType": "Boolean",
      "longFlag": "-silent",
      "key": "silent",
      "commandKey": "dnsx"
    },
    {
      "name": "Version",
      "description": "Show version of dnsx.",
      "parameterType": "Flag",
      "dataType": "Boolean",
      "longFlag": "-version",
      "key": "v",
      "commandKey": "dnsx"
    },
    {
      "name": "Show Config",
      "description": "Show configuration file location.",
      "parameterType": "Flag",
      "dataType": "Boolean",
      "longFlag": "-sc",
      "key": "sc",
      "commandKey": "dnsx"
    }
  ]
}
